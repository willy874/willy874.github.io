---

<ul class="grid grid-cols-2 gap-3 sm:grid-cols-3">
  {
    SOCIALS.map((s) => (
      <li>
        <a
          href={s.href}
          target="_blank"
          rel="me noopener noreferrer"
          aria-label={`${s.label}:${s.handle}`}
          class="social-link group flex items-center gap-3 rounded-lg border p-3 transition-colors hover:border-[var(--color-primary)]"
          style="border-color: var(--color-border); background: var(--color-surface);"
        >
          <svg
            class="size-6 shrink-0 transition-colors"
            style="color: var(--color-muted);"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d={ICONS[s.icon]} />
          </svg>
          <span class="min-w-0">
            <span class="block text-sm font-medium leading-tight">{s.label}</span>
            <span
              class="block truncate text-xs leading-tight"
              style="color: var(--color-muted);"
            >
              {s.handle}
            </span>
          </span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .social-link:hover svg {
    color: var(--color-primary) !important;
  }
</style>
