---
import ThemeToggle from './ThemeToggle.astro';
import SearchModal from '../islands/SearchModal.tsx';

const nav = [
  { href: '/posts/', label: '文章' },
  { href: '/about/', label: '關於' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header
  class="sticky top-0 z-40 border-b backdrop-blur"
  style="background-color: color-mix(in srgb, var(--color-bg) 85%, transparent); border-color: var(--color-border);"
>
  <div class="mx-auto flex h-14 max-w-5xl items-center gap-4 px-4 sm:px-6">
    <a href="/" class="font-bold tracking-tight" style="color: var(--color-primary);">
      🎋 竹子日誌
    </a>

    <nav class="ml-auto flex items-center gap-1 text-sm">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-md px-3 py-1.5 transition-colors hover:bg-[var(--color-surface)]"
            style={
              isActive(item.href)
                ? 'color: var(--color-primary); font-weight: 600;'
                : 'color: var(--color-muted);'
            }
          >
            {item.label}
          </a>
        ))
      }

      <SearchModal client:idle />
      <ThemeToggle />
    </nav>
  </div>
</header>
