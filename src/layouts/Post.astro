---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from './Base.astro';
import TOC from '../components/post/TOC.astro';
import TagBadge from '../components/post/TagBadge.astro';
import Giscus from '../components/post/Giscus.astro';
import { categoryByName } from '../lib/categories';

export interface Props {
  post: CollectionEntry<'posts'>;
  headings: MarkdownHeading[];
}
const { post, headings } = Astro.props;
const { data } = post;

const dateStr = data.publishDate.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// §5 series:同系列前後篇導覽
let seriesPosts: CollectionEntry<'posts'>[] = [];
if (data.series) {
  const all = await getCollection(
    'posts',
    (p) => !p.data.draft && p.data.series === data.series
  );
  seriesPosts = all.sort(
    (a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf()
  );
}
const idx = seriesPosts.findIndex((p) => p.id === post.id);
const prev = idx > 0 ? seriesPosts[idx - 1] : undefined;
const next = idx >= 0 && idx < seriesPosts.length - 1 ? seriesPosts[idx + 1] : undefined;

const cat = categoryByName(data.category);
---

<Base title={data.title} description={data.description} article ogImage={data.cover ? undefined : undefined}>
  <article class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[1fr_16rem]">
    <div class="min-w-0">
      <header class="mb-8">
        {
          cat && (
            <nav class="text-sm" style="color: var(--color-muted);">
              <a href="/posts/" class="hover:underline">文章</a>
              {' / '}
              <a href={`/posts/categories/${cat.slug}/`} class="hover:underline">
                {cat.emoji} {cat.name}
              </a>
            </nav>
          )
        }
        <div class="mt-1 flex items-center gap-2 text-sm" style="color: var(--color-muted);">
          <time datetime={data.publishDate.toISOString()}>{dateStr}</time>
          {data.series && <span>· 系列:{data.series}</span>}
        </div>
        <h1 class="mt-2 text-3xl font-bold leading-tight">{data.title}</h1>
        <p class="mt-3 text-lg" style="color: var(--color-muted);">{data.description}</p>
        {
          data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-1.5">
              {data.tags.map((t) => (
                <TagBadge tag={t} />
              ))}
            </div>
          )
        }
        {
          data.cover && (
            <Image
              src={data.cover}
              alt={data.title}
              width={1024}
              height={512}
              class="mt-6 aspect-[2/1] w-full rounded-lg object-cover"
            />
          )
        }
      </header>

      <div class="prose-zh">
        <slot />
      </div>

      {
        (prev || next) && (
          <nav
            class="mt-12 grid gap-3 border-t pt-6 sm:grid-cols-2"
            style="border-color: var(--color-border);"
            aria-label="系列導覽"
          >
            {prev ? (
              <a href={`/posts/${prev.id}/`} class="rounded-lg border p-3 hover:border-[var(--color-primary)]" style="border-color: var(--color-border);">
                <span class="text-xs" style="color: var(--color-muted);">← 上一篇</span>
                <div class="font-medium">{prev.data.title}</div>
              </a>
            ) : (
              <span />
            )}
            {next && (
              <a href={`/posts/${next.id}/`} class="rounded-lg border p-3 text-right hover:border-[var(--color-primary)]" style="border-color: var(--color-border);">
                <span class="text-xs" style="color: var(--color-muted);">下一篇 →</span>
                <div class="font-medium">{next.data.title}</div>
              </a>
            )}
          </nav>
        )
      }

      <Giscus />
    </div>

    <aside class="hidden lg:block">
      <div class="sticky top-20">
        <TOC headings={headings} />
      </div>
    </aside>
  </article>
</Base>
