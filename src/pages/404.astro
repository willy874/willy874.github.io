---
import Base from '../layouts/Base.astro';
---

<Base title="找不到頁面" description="404 — 這片竹林沒有這條路。">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-6xl">🎋</p>
    <h1 class="mt-4 text-4xl font-bold">404</h1>
    <p class="mt-2" style="color: var(--color-muted);">這片竹林裡沒有這條路。</p>
    <a
      href="/"
      class="mt-6 rounded-md px-4 py-2 text-sm font-medium text-white"
      style="background: var(--color-primary);"
    >
      回首頁
    </a>
  </div>
</Base>
