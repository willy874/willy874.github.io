---
import Base from '../layouts/Base.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { PROFILE, PROJECTS, FOCUS, COMMUNITY } from '../lib/profile';
---

<Base title="關於竹子" description="關於竹子(Willy):前端工程師、讀書會主辦與新手教學,以及這個技術部落格。">
  <div class="mx-auto max-w-3xl py-8">
    <h1 class="text-3xl font-bold">關於竹子</h1>

    <div class="prose-zh mt-4">
      <p>
        你好,我是<strong>竹子</strong>(Willy),一名前端工程師,{PROFILE.since} 年入行。
        這些年待過直銷電商、微前端框架、Web App 到企業內部系統,
        從寫元件、搭架構到重構舊專案都做過。
      </p>
      <p>
        比起把功能刻出來,我更著迷於「專案要怎麼設計才好維護」——
        測試文化、型別系統、設計系統、打包工具鏈、Monorepo,
        這些看不見卻決定專案壽命的東西,是我平常最喜歡打磨的地方。
      </p>
      <p>
        假日我會開<strong>線上線下讀書會</strong>,和同領域的朋友交流;
        平日晚間帶<strong>新手教學</strong>,有任何問題都歡迎私下發問。
        這個站集中我所有的文字產出——技術寫作、學習筆記與主題分享,
        以繁體中文為主,涵蓋前端技術、工程實務、設計系統、AI 工作流,
        以及職涯、商業與各種議題反思。
      </p>
    </div>

    <!-- 專注領域 -->
    <section class="mt-10">
      <h2 class="text-xl font-bold">專注領域</h2>
      <div class="mt-3 grid gap-3 sm:grid-cols-3">
        {
          FOCUS.map((f) => (
            <div
              class="rounded-lg border p-4"
              style="border-color: var(--color-border); background: var(--color-surface);"
            >
              <div class="font-bold" style="color: var(--color-primary);">
                {f.title}
              </div>
              <p class="mt-1 text-sm" style="color: var(--color-muted);">
                {f.desc}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- 內容形態 -->
    <section class="mt-10">
      <h2 class="text-xl font-bold">這裡有什麼</h2>
      <ul class="prose-zh mt-3">
        <li><strong>文章</strong>:依 12 個分類區塊整理的技術與反思長文</li>
        <li><strong>互動工具</strong>:如紫微命盤等獨立 HTML 工具頁</li>
        <li><strong>檔案庫</strong>:履歷、PDF 等靜態附件</li>
      </ul>
    </section>

    <!-- 精選專案 -->
    <section class="mt-10">
      <h2 class="text-xl font-bold">精選專案</h2>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        {
          PROJECTS.map((p) => (
            <a
              href={p.href}
              class="rounded-lg border p-4 transition-colors hover:border-[var(--color-primary)]"
              style="border-color: var(--color-border); background: var(--color-surface);"
            >
              <div class="font-mono text-sm font-bold" style="color: var(--color-primary);">
                {p.name}
              </div>
              <p class="mt-1 text-sm" style="color: var(--color-muted);">
                {p.desc}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- 社群經歷 -->
    <section class="mt-10">
      <h2 class="text-xl font-bold">社群經歷</h2>
      <ul class="prose-zh mt-3">
        {
          COMMUNITY.map((c) => (
            <li>
              {c.href ? (
                <a href={c.href} target="_blank" rel="noopener" style="color: var(--color-primary);">
                  {c.text}
                </a>
              ) : (
                c.text
              )}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- 聯絡與社群 -->
    <section class="mt-10">
      <h2 class="text-xl font-bold">聯絡與社群</h2>
      <p class="mt-3 text-sm" style="color: var(--color-muted);">
        Email:<a href={`mailto:${PROFILE.email}`} style="color: var(--color-primary);">{PROFILE.email}</a>
        ｜ <a
          href="https://docs.google.com/document/d/1oqnaUNemDmZNIoHFG2239EnZ7D6VaQsh2a0EqGEs0I0/edit"
          target="_blank"
          rel="noopener"
          style="color: var(--color-primary);"
        >履歷</a>
      </p>
      <div class="mt-4">
        <SocialLinks />
      </div>
    </section>

    <p class="mt-10 text-sm" style="color: var(--color-muted);">
      本站以 Astro 建構,託管於 GitHub Pages,原始碼在
      <a href="https://github.com/willy874/willy874.github.io" style="color: var(--color-primary);">GitHub</a>。
    </p>
  </div>
</Base>
