---
import Base from '../layouts/Base.astro';
import PostCard from '../components/post/PostCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getPublishedPosts } from '../lib/categories';
import { PROFILE, PROJECTS } from '../lib/profile';

const posts = await getPublishedPosts();
const recent = posts.slice(0, 8);
---

<Base title="竹子日誌">
  <!-- Hero -->
  <section class="py-8 sm:py-12">
    <p class="text-sm font-medium" style="color: var(--color-primary);">
      {PROFILE.tagline}
    </p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
      🎋 竹子日誌
    </h1>
    <p class="mt-4 max-w-2xl text-lg" style="color: var(--color-muted);">
      {PROFILE.intro}
    </p>
  </section>

  <!-- 近期文章 -->
  <section class="py-8">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="text-xl font-bold">近期文章</h2>
      <a href="/posts/" class="text-sm hover:underline" style="color: var(--color-primary);">全部 →</a>
    </div>
    {
      recent.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2">
          {recent.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p style="color: var(--color-muted);">尚無文章,敬請期待。</p>
      )
    }
  </section>

  <!-- 精選專案 -->
  <section class="py-8">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="text-xl font-bold">精選專案</h2>
      <a href="https://github.com/willy874?tab=repositories" class="text-sm hover:underline" style="color: var(--color-primary);">
        GitHub →
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        PROJECTS.map((p) => (
          <a
            href={p.href}
            class="flex flex-col rounded-lg border p-4 transition-colors hover:border-[var(--color-primary)]"
            style="border-color: var(--color-border); background: var(--color-surface);"
          >
            <span class="font-mono text-sm font-bold" style="color: var(--color-primary);">
              {p.name}
            </span>
            <span class="mt-1 flex-1 text-sm" style="color: var(--color-muted);">
              {p.desc}
            </span>
            <span class="mt-3 flex flex-wrap gap-1.5">
              {p.tags.map((t) => (
                <span
                  class="rounded-full border px-2 py-0.5 text-xs"
                  style="border-color: var(--color-border); color: var(--color-muted);"
                >
                  {t}
                </span>
              ))}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 社群連結 -->
  <section class="py-8">
    <h2 class="mb-4 text-xl font-bold">社群媒體</h2>
    <SocialLinks />
  </section>
</Base>
