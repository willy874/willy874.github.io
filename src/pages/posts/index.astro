---
import Base from '../../layouts/Base.astro';
import TagBadge from '../../components/post/TagBadge.astro';
import { CATEGORIES, getPublishedPosts } from '../../lib/categories';

const posts = await getPublishedPosts();

// 各分類統計與最新數篇
const byCategory = CATEGORIES.map((cat) => {
  const items = posts.filter((p) => p.data.category === cat.name);
  return { cat, count: items.length, latest: items.slice(0, 4) };
}).filter((g) => g.count > 0);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
const fmtDate = (d: Date) => d.toLocaleDateString('zh-TW');
---

<Base title="文章" description="竹子日誌全部文章,依 12 個分類區塊整理:前端技術、工程實務、設計、AI、職涯、商業、議題討論等。">
  <div class="py-6">
    <header class="mb-8">
      <h1 class="text-3xl font-bold">文章</h1>
      <p class="mt-2" style="color: var(--color-muted);">
        共 {posts.length} 篇,分為 {byCategory.length} 個分類區塊。
      </p>
    </header>

    <!-- 分類區塊 -->
    <div class="space-y-10">
      {
        byCategory.map(({ cat, count, latest }) => (
          <section aria-label={cat.name}>
            <div class="mb-3 flex items-baseline justify-between gap-3">
              <h2 class="text-xl font-bold">
                <a href={`/posts/categories/${cat.slug}/`} class="hover:text-[var(--color-primary)]">
                  {cat.emoji} {cat.name}
                </a>
                <span class="ml-2 text-sm font-normal" style="color: var(--color-muted);">
                  {count} 篇
                </span>
              </h2>
              <a
                href={`/posts/categories/${cat.slug}/`}
                class="shrink-0 text-sm hover:underline"
                style="color: var(--color-primary);"
              >
                查看全部 →
              </a>
            </div>
            <p class="mb-3 text-sm" style="color: var(--color-muted);">
              {cat.blurb}
            </p>
            <ul class="grid gap-2 sm:grid-cols-2">
              {latest.map((post) => (
                <li>
                  <a
                    href={`/posts/${post.id}/`}
                    class="flex gap-3 rounded-md border p-3 transition-colors hover:border-[var(--color-primary)]"
                    style="border-color: var(--color-border);"
                  >
                    <time
                      class="shrink-0 text-xs tabular-nums"
                      style="color: var(--color-muted);"
                      datetime={post.data.publishDate.toISOString()}
                    >
                      {fmtDate(post.data.publishDate)}
                    </time>
                    <span class="line-clamp-1 text-sm font-medium">{post.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    {
      allTags.length > 0 && (
        <section class="mt-12 border-t pt-8" style="border-color: var(--color-border);">
          <h2 class="mb-3 text-lg font-bold">依標籤瀏覽</h2>
          <div class="flex flex-wrap gap-1.5">
            {allTags.map((t) => (
              <TagBadge tag={t} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</Base>
