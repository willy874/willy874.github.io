---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/post/PostCard.astro';
import TagBadge from '../../components/post/TagBadge.astro';

const posts = (await getCollection('posts', (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Base title="文章" description="竹子日誌的全部文章,涵蓋 Zero-Trust、前端工程與 AI 工作流。">
  <div class="py-6">
    <h1 class="text-3xl font-bold">文章</h1>

    {
      allTags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1.5">
          {allTags.map((t) => (
            <TagBadge tag={t} />
          ))}
        </div>
      )
    }

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>

    {posts.length === 0 && <p style="color: var(--color-muted);">尚無文章。</p>}
  </div>
</Base>
