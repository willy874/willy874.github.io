---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

// §5 talks 用 data collection:列表頁純讀 YAML metadata 渲染,簡報本體是獨立 HTML
const talks = (await getCollection('talks')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="演講" description="竹子的技術演講與簡報存檔,可獨立分享的乾淨網址。">
  <div class="py-6">
    <h1 class="text-3xl font-bold">演講</h1>
    <p class="mt-2" style="color: var(--color-muted);">
      簡報以獨立全螢幕頁保存,點卡片即開。部分簡報為第三方工具產出,無障礙標準見規劃書 §7.4。
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        talks.map((talk) => (
          <article
            class="flex flex-col rounded-lg border p-5"
            style="border-color: var(--color-border); background: var(--color-surface);"
          >
            <div class="flex items-center gap-2 text-xs" style="color: var(--color-muted);">
              <time datetime={talk.data.date.toISOString()}>
                {talk.data.date.toLocaleDateString('zh-TW')}
              </time>
              <span>· {talk.data.event}</span>
            </div>
            <h2 class="mt-1 text-lg font-bold">{talk.data.title}</h2>
            <p class="mt-2 flex-1 text-sm" style="color: var(--color-muted);">
              {talk.data.abstract}
            </p>
            <div class="mt-4 flex flex-wrap gap-2 text-sm">
              <a
                href={talk.data.slideUrl}
                class="rounded-md px-3 py-1.5 font-medium text-white"
                style="background: var(--color-primary);"
              >
                開啟簡報
              </a>
              {talk.data.pdfUrl && (
                <a
                  href={talk.data.pdfUrl}
                  class="rounded-md border px-3 py-1.5"
                  style="border-color: var(--color-border);"
                >
                  PDF
                </a>
              )}
              {talk.data.videoUrl && (
                <a
                  href={talk.data.videoUrl}
                  class="rounded-md border px-3 py-1.5"
                  style="border-color: var(--color-border);"
                >
                  錄影
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>

    {talks.length === 0 && <p style="color: var(--color-muted);">尚無演講資料。</p>}
  </div>
</Base>
